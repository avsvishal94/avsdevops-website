{
  "name": "avsdevops-website",
  "version": "1.0.0",
  "description": "AVSDevOps — DevOps, Cloud & AI/ML Ops Training Platform",
  "type": "module",
  "scripts": {
    "start": "node serve.mjs",
    "dev": "node serve.mjs",
    "docker:build": "docker build -t avsdevops-website:latest .",
    "docker:run": "docker run -p 8080:8080 --name avsdevops-web avsdevops-website:latest",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "k8s:deploy": "kubectl apply -f k8s/namespace.yaml && kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete namespace avsdevops",
    "k8s:status": "kubectl get all -n avsdevops",
    "vercel:dev": "vercel dev",
    "vercel:deploy": "vercel --prod"
  },
  "keywords": ["devops", "cloud", "aiops", "mlops", "kubernetes", "docker"],
  "author": "AVSDevOps",
  "license": "ISC"
}
